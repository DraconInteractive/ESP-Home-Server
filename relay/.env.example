RELAY_HOST=127.0.0.1
RELAY_PORT=8080
RELAY_DATABASE_PATH=/opt/spoken-command-relay/relay-state.sqlite3
RELAY_DEVICE_TOKENS_PATH=/opt/spoken-command-relay/device-tokens.json

# Generate long random values before deployment.
RELAY_DEVICE_ENROLL_TOKEN=replace-with-device-enrollment-token
RELAY_SYNC_TOKEN=replace-with-home-server-sync-token
RELAY_DASHBOARD_TOKEN=replace-with-dashboard-token
RELAY_ADMIN_TOKEN=replace-with-admin-token

# Optional dashboard phone-code login through ntfy.
RELAY_NTFY_URL=https://ntfy.sh
RELAY_NTFY_TOPIC=
RELAY_NTFY_TOKEN=
RELAY_NTFY_TITLE=Dracon Relay
RELAY_DASHBOARD_CODE_TTL_SECONDS=300
RELAY_DASHBOARD_CODE_REQUEST_SECONDS=60
RELAY_DASHBOARD_SESSION_SECONDS=43200

# Pending events are redelivered if the home server does not ack before this.
RELAY_EVENT_LEASE_SECONDS=60
