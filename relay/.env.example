export RELAY_HOST="127.0.0.1"
export RELAY_PORT="8080"
export RELAY_DATABASE_PATH="/opt/spoken-command-relay/relay-state.sqlite3"
export RELAY_DEVICE_TOKENS_PATH="/opt/spoken-command-relay/device-tokens.json"

# Generate long random values before deployment.
export RELAY_DEVICE_ENROLL_TOKEN="replace-with-device-enrollment-token"
export RELAY_SYNC_TOKEN="replace-with-home-server-sync-token"
export RELAY_DASHBOARD_TOKEN="replace-with-dashboard-token"
export RELAY_ADMIN_TOKEN="replace-with-admin-token"

# Pending events are redelivered if the home server does not ack before this.
export RELAY_EVENT_LEASE_SECONDS="60"
