export ELEVENLABS_API_KEY="replace-with-your-key"
export COMMAND_SERVER_HOST="0.0.0.0"
export COMMAND_SERVER_PORT="8080"

# Optional packaged email action.
export COMMAND_SERVER_SMTP_HOST=""
export COMMAND_SERVER_SMTP_PORT="587"
export COMMAND_SERVER_SMTP_USERNAME=""
export COMMAND_SERVER_SMTP_PASSWORD=""
export COMMAND_SERVER_SMTP_STARTTLS="1"
export COMMAND_SERVER_SMTP_SSL="0"
export COMMAND_SERVER_EMAIL_FROM=""
# Optional defaults. If unset, the spoken action must provide these.
export COMMAND_SERVER_EMAIL_TO=""
export COMMAND_SERVER_EMAIL_SUBJECT=""
export COMMAND_SERVER_EMAIL_ALLOW_FREEFORM_TO="0"

# Optional packaged ntfy phone notification action.
export COMMAND_SERVER_NTFY_URL="https://ntfy.sh"
export COMMAND_SERVER_NTFY_TOPIC=""
export COMMAND_SERVER_NTFY_TITLE="Spoken Command"
export COMMAND_SERVER_NTFY_PRIORITY="default"
export COMMAND_SERVER_NTFY_TAGS="bell"
